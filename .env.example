# .env.example — Copy to .env and fill in your values.
#
# NEVER commit .env to git — it's listed in .gitignore.

# GitHub Personal Access Token (recommended).
# Without this, the GitHub API is limited to 60 requests/hour.
# Create one at: https://github.com/settings/tokens
# Required scopes: none (public repos only) or 'repo' for private repos.
GITHUB_TOKEN=ghp_your_token_here

# Port the Go API listens on (default: 8080)
PORT=8080

# Astro frontend: URL of the Go API (used by Vite proxy in dev)
# In production, set this to your deployed API URL (e.g. https://api.devpulse.example.com)
VITE_API_URL=http://localhost:8080
