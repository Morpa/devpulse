---
interface Props {
	title?: string;
}
const { title = "DevPulse" } = Astro.props;
---

<!doctype html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="DevPulse — Monitor de saúde de repositórios GitHub em tempo real" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><circle cx='16' cy='16' r='12' fill='%233fb950'/><circle cx='16' cy='16' r='6' fill='%23080b0d'/></svg>"
    />
  </head>

  <body class="crt min-h-screen bg-void text-ink-base font-mono antialiased">

    <!-- Nav -->
    <header class="sticky top-0 z-50 border-b border-border bg-void/90 backdrop-blur-sm">
      <nav class="max-w-7xl mx-auto px-4 h-14 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3">
          <span class="w-2.5 h-2.5 rounded-full bg-phosphor-base animate-glow-pulse"></span>
          <span class="text-phosphor-bright font-semibold tracking-widest text-sm text-glow">
            DEV<span class="text-ink-base">PULSE</span>
          </span>
        </a>
        <div class="flex items-center gap-5 text-xs text-ink-subtle">
          <span id="nav-count">0 repos</span>
          <a href="https://github.com" target="_blank" rel="noopener" class="hover:text-phosphor-base transition-colors">
            GitHub ↗
          </a>
        </div>
      </nav>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-border mt-16 py-6 text-center text-xs text-ink-dim">
      DevPulse · Astro 5 + React 19 + Tailwind 4 + Go + Gin
    </footer>

  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
